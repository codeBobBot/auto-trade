# ========================================
# Polymarket 套利系统配置文件
# ========================================

# API 配置
# 从 https://polymarket.com/ 获取 API Key
POLYMARKET_API_KEY="your_api_key_here"
POLYMARKET_API_SECRET="your_api_secret_here"
POLYMARKET_API_PASSPHRASE="your_passphrase_here"

# Polygon 私钥（用于交易签名）
POLYGON_PRIVATE_KEY="your_polygon_private_key_here"

# Tavily API（新闻搜索）
TAVILY_API_KEY="your_tavily_api_key_here"

# ========================================
# 风险控制配置
# ========================================

# 仓位管理
MAX_POSITION_SIZE=0.1              # 单笔最大仓位比例 (10%)
MAX_TOTAL_EXPOSURE=0.3             # 总仓位上限 (30%)

# 损失限制
MAX_DAILY_LOSS_USD=50              # 日损失限制 ($50)
MAX_TRADE_AMOUNT_USD=10            # 单笔交易金额上限 ($10)

# 止损止盈
STOP_LOSS_PERCENTAGE=10            # 止损百分比 (10%)
TAKE_PROFIT_PERCENTAGE=20          # 止盈百分比 (20%)

# 市场相关性
MAX_CORRELATION=0.7                # 最大市场相关性阈值

# ========================================
# 策略配置
# ========================================

# 策略权重 (总和应为 1.0)
SENTIMENT_STRATEGY_WEIGHT=0.4      # 情绪策略权重
PRICE_STRATEGY_WEIGHT=0.6          # 价格策略权重

# 置信度阈值
MIN_CONFIDENCE=0.3                 # 最低置信度阈值
MIN_SIGNAL_QUALITY=0.5             # 最低信号质量分数

# ========================================
# 错误处理配置
# ========================================

# API 重试
MAX_RETRIES=3                      # 最大重试次数
RETRY_DELAY=1.0                    # 重试延迟（秒）
MAX_RETRY_DELAY=30.0               # 最大重试延迟（秒）
EXPONENTIAL_BACKOFF=true           # 是否启用指数退避

# 熔断器
CIRCUIT_BREAKER_THRESHOLD=5        # 熔断器失败阈值
CIRCUIT_BREAKER_TIMEOUT=60         # 熔断器超时时间（秒）

# ========================================
# 监控告警配置
# ========================================

# Telegram 通知
TELEGRAM_BOT_TOKEN=""              # Telegram Bot Token
TELEGRAM_CHAT_ID=""                # Telegram Chat ID

# 邮件通知（可选）
SMTP_SERVER=""                     # SMTP 服务器
SMTP_PORT=587                      # SMTP 端口
EMAIL_USER=""                      # 邮箱用户名
EMAIL_PASSWORD=""                  # 邮箱密码

# 告警静默期
ALERT_SILENCE_DURATION=30          # 告警静默期（分钟）

# ========================================
# 回测配置
# ========================================

BACKTEST_INITIAL_CAPITAL=1000      # 回测初始资金
BACKTEST_COMMISSION_RATE=0.01      # 回测手续费率 (1%)
BACKTEST_SLIPPAGE=0.005            # 回测滑点 (0.5%)

# ========================================
# 网络配置
# ========================================

# 可选: 代理配置
# HTTP_PROXY="http://127.0.0.1:7890"
# HTTPS_PROXY="http://127.0.0.1:7890"

# API 超时
API_TIMEOUT=30                      # API 请求超时（秒）
API_RATE_LIMIT=5                    # API 速率限制（请求/秒）

# ========================================
# 日志配置
# ========================================

LOG_LEVEL=INFO                     # 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_FILE="./logs/trading.log"      # 日志文件路径
LOG_MAX_SIZE=10485760              # 日志文件最大大小 (10MB)
LOG_BACKUP_COUNT=5                 # 日志备份数量

# ========================================
# 全球舆情模块配置
# ========================================

# 新闻数据源
NEWSAPI_KEY=""                     # NewsAPI Key (https://newsapi.org)
GNEWS_KEY=""                       # GNews API Key (https://gnews.io)

# Twitter/X 数据源
TWITTER_BEARER_TOKEN=""            # Twitter Bearer Token
TWITTER_API_KEY=""                 # Twitter API Key
TWITTER_API_SECRET=""              # Twitter API Secret

# Reddit 数据源
REDDIT_CLIENT_ID=""                # Reddit Client ID
REDDIT_CLIENT_SECRET=""            # Reddit Client Secret
REDDIT_USER_AGENT="PolymarketSentimentBot/1.0"

# 翻译服务（多语言支持）
GOOGLE_TRANSLATE_API_KEY=""        # Google Translate API Key
DEEPL_API_KEY=""                   # DeepL API Key
LIBRETRANSLATE_URL="https://libretranslate.com"

# 舆情预警阈值
SENTIMENT_EXTREME_THRESHOLD=0.7    # 极端情绪阈值
SENTIMENT_ANOMALY_THRESHOLD=2.0    # 异常检测 Z-score 阈值
SENTIMENT_VOLATILITY_THRESHOLD=0.3 # 高波动阈值

# 舆情缓存配置
SENTIMENT_CACHE_TTL=3600           # 舆情缓存 TTL（秒）
SENTIMENT_CACHE_MAX_ITEMS=500      # 舆情缓存最大条目数
